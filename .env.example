# =============================================================================
# TaxProHelpDesk Training Academy — environment variables
# Copy to .env.local for local dev, and set the same in Vercel project settings.
# =============================================================================

# ---- Supabase (Database + Auth) --------------------------------------------
# Browser-safe (exposed to the client). The anon key is RLS-gated.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. BYPASSES RLS — used in trusted server actions to invite users,
# set roles, and assign tracks/bureaus. NEVER expose to the client / browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-NOT-the-anon-key

# ---- App -------------------------------------------------------------------
# Public base URL of the deployed app — used to build invite/redirect links.
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Branding (optional overrides; sensible defaults in lib/constants.ts) --
NEXT_PUBLIC_LOGO_URL=https://taxprohelpdesk.com/images/logo.png
NEXT_PUBLIC_SUPPORT_PHONE=(866) 377-4139

# ---- Seed script (server-side only; reuses the values above) ---------------
# The seed script (scripts/seed.mjs) needs SUPABASE service role to load content.
# It reads NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY from this file.
